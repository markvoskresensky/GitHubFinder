    "authorization_screen_intro_text" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sign in with your GitHub account to raise the rate limit and access more data."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Войдите через аккаунт GitHub, чтобы поднять лимит запросов и получить доступ к большему количеству данных."
          }
        }
      }
    },
