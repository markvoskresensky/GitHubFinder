      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enter this code on GitHub:"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Введите этот код на GitHub:"
