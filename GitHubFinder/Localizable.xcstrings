      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sign-in failed"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не удалось войти"
